		"prettier-plugin-organize-attributes": "1.0.0",
		"prettier-plugin-tailwindcss": "0.7.2",
		"tailwindcss": "4.2.2",
		"typescript": "5.9.3",
		"vite": "8.0.8",
		"vite-plugin-mkcert": "2.0.0",
